<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <!-- Stays white in both themes: on-brand text/icons over the brand-filled buttons. -->
    <color name="white">#FFFFFFFF</color>

    <!-- Brand. brand = the indigo accent used across screens; brand_blue = the older primary blue.
         Both collapse to the same lighter indigo in dark mode (see values-night). -->
    <color name="brand">#FF4F46E5</color>
    <color name="brand_blue">#FF2563EB</color>

    <!-- Surfaces -->
    <color name="surface">#FFFFFFFF</color>        <!-- cards, sheets, headers -->
    <color name="surface_page">#FFF8FAFC</color>   <!-- screen background -->
    <color name="icon_chip_bg">#FFE0E7FF</color>   <!-- rounded icon container behind list icons -->

    <!-- Text / icons -->
    <color name="text_dark">#FF111827</color>      <!-- headings, primary text, dark icons -->
    <color name="text_muted">#FF6B7280</color>
    <color name="text_hint">#FF9CA3AF</color>

    <!-- Dividers / strokes -->
    <color name="surface_gray">#FFE5E7EB</color>   <!-- divider / hairline stroke -->
    <color name="divider_light">#FFF3F4F6</color>

    <!-- Semantic (in/out, alerts) -->
    <color name="danger_red">#FFDC2626</color>
    <color name="danger_red_bg">#FFFEE2E2</color>
    <color name="danger_stroke">#FFFECACA</color>
    <color name="success_green">#FF16A34A</color>
    <color name="success_green_bg">#FFDCFCE7</color>
    <color name="unselected_gray">#FFD1D5DB</color>

    <!-- Amber warning (unverified phone banner etc.) -->
    <color name="amber_text">#FF92400E</color>
    <color name="amber_bg">#FFFEF3C7</color>
    <color name="amber_icon">#FFD97706</color>

    <!-- Date header row -->
    <color name="date_header_bg">#FFF0F2F5</color>
    <color name="date_header_text">#FF374151</color>
</resources>
