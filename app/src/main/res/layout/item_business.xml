<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTintMode="src_over"
    android:layout_marginBottom="10dp"
    android:padding="12dp"
    android:background="@drawable/bg_target_row_unselected">

    <FrameLayout
        android:id="@+id/business_icon_container"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/round_shape"
        android:backgroundTint="@color/icon_chip_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/business_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_book_decor"
            app:tint="@color/brand" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/business_details"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@id/business_settings_gear"
        app:layout_constraintStart_toEndOf="@id/business_icon_container"
        app:layout_constraintTop_toTopOf="@id/business_icon_container">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/business_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="160dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Studio House"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/business_role_pill"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_pill">

                <TextView
                    android:id="@+id/business_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:paddingHorizontal="8dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="OWNER"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/business_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="3 books"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/business_settings_gear"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_icon_square"
        android:contentDescription="Business settings"
        android:padding="8dp"
        android:src="@drawable/ic_nav_settings"
        app:layout_constraintBottom_toBottomOf="@id/business_icon_container"
        app:layout_constraintEnd_toStartOf="@id/selected_indicator"
        app:layout_constraintTop_toTopOf="@id/business_icon_container"
        app:tint="@color/brand" />

    <ImageView
        android:id="@+id/selected_indicator"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_radio_unchecked"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/unselected_gray"
        tools:src="@drawable/ic_check_circle"
        tools:tint="@color/success_green" />
</androidx.constraintlayout.widget.ConstraintLayout>
