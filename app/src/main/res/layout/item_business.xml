<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTintMode="src_over"
    android:paddingHorizontal="4dp"
    android:paddingVertical="12dp"
    android:background="#FFFFFF">

    <FrameLayout
        android:id="@+id/business_icon_container"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/round_shape"
        android:backgroundTint="#E3F2FD"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/business_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#1565C0" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/business_details"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@id/selected_indicator"
        app:layout_constraintStart_toEndOf="@id/business_icon_container"
        app:layout_constraintTop_toTopOf="@id/business_icon_container">

        <TextView
            android:id="@+id/business_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Studio House"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/business_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Owner"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/business_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3 books"
            android:textColor="#6B7280"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/selected_indicator"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/checkbox_on_background"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#2563EB"
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>
