<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- ═══════════════════════════════════════════
         TOP APP BAR  (no extra padding / margins)
    ═══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="2dp">

        <!-- Toolbar: back | title+subtitle | [space] | icons -->
        <LinearLayout
            android:id="@+id/details_toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- ← Back arrow -->
            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#111827" />

            <!-- Title + subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="2dp">

                <TextView
                    android:id="@+id/toolbar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="June entries"
                    android:textColor="#111827"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/toolbar_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Member, Book Activity etc"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/toolbar_add_member"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add Member"
                android:padding="9dp"
                android:src="@drawable/ic_person_add"
                app:tint="#4F46E5" />

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_pill_outline">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="PDF"
                    android:textColor="#4F46E5"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/toolbar_more"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="More options"
                android:padding="9dp"
                android:src="@drawable/ic_more_vert"
                app:tint="#4F46E5" />
        </LinearLayout>

        <!-- ── Search bar ── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp"
            android:hint="Search by remark or amount"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="#9CA3AF"
            app:endIconMode="clear_text"
            app:endIconTint="#9CA3AF"
            app:hintTextColor="#9CA3AF"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:boxBackgroundColor="#F3F4F6">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/search_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:inputType="text"
                android:background="@null"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical"
                android:textSize="14sp"
                android:textColor="#111827" />
        </com.google.android.material.textfield.TextInputLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════
         CONTENT BELOW APP BAR: fixed balance card + scrollable entries
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ── Balance summary card (sticky, does not scroll) ── -->
        <LinearLayout
            android:id="@+id/balance_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="0dp">

                <!-- Net Balance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NET BALANCE"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:letterSpacing="0.04" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_entries_in_book"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0 entries this book"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_net_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs 0"
                            android:textColor="#111827"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" />

                <!-- Total In / Total Out side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/round_shape"
                            android:backgroundTint="#DCFCE7">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_arrow_up_right"
                                app:tint="#16A34A" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total In"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_total_in"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rs 0"
                                android:textColor="#16A34A"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="34dp" android:background="#E5E7EB" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/round_shape"
                            android:backgroundTint="#FEE2E2">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_arrow_down_left"
                                app:tint="#DC2626" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Out"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_total_out"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rs 0"
                                android:textColor="#DC2626"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" />

                <!-- VIEW REPORTS -->
                <TextView
                    android:id="@+id/btn_view_reports"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="VIEW REPORTS  ›"
                    android:textColor="#4F46E5"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:background="?attr/selectableItemBackground" />

        </LinearLayout>

        <!-- ── Scrollable entries (balance card above stays fixed) ── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="90dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── "Showing N entries" ── -->
                <TextView
                    android:id="@+id/tv_entry_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp"
                    android:gravity="center"
                    android:text="Showing 0 entries"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <!-- ── Date header ── -->
                <TextView
                    android:id="@+id/tv_date_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text=""
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="#F0F2F5" />

                <!-- ── Dynamic entry rows injected by Activity ── -->
                <LinearLayout
                    android:id="@+id/entry_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         BOTTOM  CASH IN | CASH OUT  bar
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F0F2F5"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:layout_gravity="bottom">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cash_in"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="CASH IN"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:backgroundTint="#16A34A"
            app:icon="@android:drawable/ic_input_add"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:cornerRadius="26dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cash_out"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="CASH OUT"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:backgroundTint="#DC2626"
            app:icon="@drawable/ic_minus"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:cornerRadius="26dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>