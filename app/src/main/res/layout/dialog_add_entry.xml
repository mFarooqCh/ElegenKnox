<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ── Header bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <FrameLayout
            android:id="@+id/dialog_icon_bg"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/round_shape"
            android:backgroundTint="#DCFCE7">

            <ImageView
                android:id="@+id/dialog_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_plus"
                app:tint="#16A34A" />
        </FrameLayout>

        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Cash In Entry"
            android:textColor="#16A34A"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp" />

        <ImageButton
            android:id="@+id/dialog_back_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"
            app:tint="#6B7280" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" />

    <!-- ── Date & Time row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Date picker -->
        <LinearLayout
            android:id="@+id/btn_pick_date"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_outline"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar"
                android:contentDescription="Date"
                app:tint="#6B7280" />

            <TextView
                android:id="@+id/tv_selected_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="28/06/2026"
                android:textColor="#111827"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Time picker -->
        <LinearLayout
            android:id="@+id/btn_pick_time"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_outline"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_clock"
                android:contentDescription="Time"
                app:tint="#6B7280" />

            <TextView
                android:id="@+id/tv_selected_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="11:39 pm"
                android:textColor="#111827"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" />

    <!-- ── Amount field ── -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_amount"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="20dp"
        android:hint="Amount *"
        app:hintTextColor="#DC2626"
        app:boxStrokeColor="#2563EB"
        app:boxStrokeWidth="2dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="#16A34A"
            android:textSize="22sp"
            android:textStyle="bold" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── Remark field ── -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_remark"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:hint="Remark (optional)"
        app:boxStrokeColor="#D1D5DB"
        app:boxStrokeWidth="1dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_remark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:textColor="#111827"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── Save / Save & Add New buttons ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_add_new"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="SAVE &amp; ADD NEW"
            android:textAllCaps="true"
            android:textSize="12sp"
            android:textColor="#374151"
            app:strokeColor="#D1D5DB"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="SAVE"
            android:textAllCaps="true"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB"
            app:cornerRadius="14dp" />

    </LinearLayout>

</LinearLayout>