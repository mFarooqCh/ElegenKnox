<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════
         TOP APP BAR  — sits below status bar
    ═══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/top_app_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/round_shape"
                android:backgroundTint="#E0E7FF">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_book_decor"
                    app:tint="#4F46E5" />
            </FrameLayout>

            <!-- Business name + subtitle -->
            <LinearLayout
                android:id="@+id/business_selector"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/business_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ElegenSol"
                        android:textColor="#0F172A"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <ImageView
                        android:id="@+id/business_caret"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_chevron_down"
                        app:tint="#6B7280" />
                </LinearLayout>

                <TextView
                    android:id="@+id/business_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to switch business"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/add_members_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add Members"
                android:padding="9dp"
                android:src="@drawable/ic_person_add"
                app:tint="#4F46E5" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════
         SCROLLABLE BODY
    ═══════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="24dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_app_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Indigo hero card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/hero_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#4F46E5"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Basics of CashBook"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Learn to use cashbook"
                            android:textColor="#E0E7FF"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/know_more_button"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginTop="16dp"
                            android:paddingHorizontal="16dp"
                            android:text="Know more"
                            android:textAllCaps="false"
                            android:textColor="#4F46E5"
                            android:textStyle="bold"
                            android:backgroundTint="#FFFFFF"
                            app:icon="@android:drawable/ic_media_play"
                            app:iconGravity="end"
                            app:iconSize="14dp"
                            app:iconTint="#4F46E5"
                            app:cornerRadius="20dp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/hero_dismiss_button"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Dismiss"
                        android:padding="8dp"
                        android:src="@drawable/ic_close"
                        app:tint="#E0E7FF" />

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="end|bottom"
                        android:layout_margin="18dp"
                        android:alpha="0.9"
                        android:src="@drawable/ic_book_decor"
                        app:tint="#FFFFFF" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your Books"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/filter_books_button"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Filter"
                    android:padding="6dp"
                    android:src="@drawable/ic_filter"
                    app:tint="#4F46E5" />

                <ImageButton
                    android:id="@+id/search_books_button"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Search"
                    android:padding="6dp"
                    android:src="@drawable/ic_search"
                    app:tint="#4F46E5" />
            </LinearLayout>

            <!-- Tip card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tip_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#EEF2FF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="6dp"
                    android:paddingVertical="6dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lightbulb"
                        app:tint="#4F46E5" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Tap to view your entries in this book"
                        android:textColor="#4F46E5"
                        android:textSize="13sp" />

                    <ImageButton
                        android:id="@+id/tip_dismiss_button"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Dismiss tip"
                        android:padding="8dp"
                        android:src="@drawable/ic_close"
                        app:tint="#9CA3AF" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Empty-state suggestions — shown instead of tip_card when there are no books yet -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/empty_books_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:backgroundTint="#EEF2FF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No books yet — quick start"
                        android:textColor="#4F46E5"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/empty_books_suggestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:singleLine="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_suggest_june"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="June Expenses"
                            android:textColor="#4F46E5"
                            app:chipBackgroundColor="#FFFFFF"
                            app:chipStrokeWidth="0dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_suggest_petty"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Petty Cash Book"
                            android:textColor="#4F46E5"
                            app:chipBackgroundColor="#FFFFFF"
                            app:chipStrokeWidth="0dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_suggest_project"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Project Book"
                            android:textColor="#4F46E5"
                            app:chipBackgroundColor="#FFFFFF"
                            app:chipStrokeWidth="0dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_suggest_client"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Client Record"
                            android:textColor="#4F46E5"
                            app:chipBackgroundColor="#FFFFFF"
                            app:chipStrokeWidth="0dp" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Books RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/books_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <!-- Bottom spacing so FAB never overlaps last item -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════
         BOTTOM NAVIGATION  — sits above nav bar
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/nav_indicator_row"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="@id/bottom_navigation">

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <View android:layout_width="40dp" android:layout_height="3dp" android:layout_gravity="center" android:background="@drawable/bg_nav_indicator" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@color/nav_tab_tint"
        app:itemTextColor="@color/nav_tab_tint"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />

    <!-- ═══════════════════════════════════════════
         FAB — Add New Book
    ═══════════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_book_button"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingStart="24dp"
        android:paddingEnd="28dp"
        android:text="ADD NEW BOOK"
        android:textAllCaps="true"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.03"
        android:backgroundTint="#4F46E5"
        app:icon="@android:drawable/ic_input_add"
        app:iconSize="20dp"
        app:iconTint="#FFFFFF"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:cornerRadius="28dp"
        app:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>