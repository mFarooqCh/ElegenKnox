<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Same @color/ references as the light theme (they resolve to the dark palette here); only the
         light-bar flags flip so status/nav icons render light-on-dark. -->
    <style name="Base.Theme.ElegenCashBook" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/surface_page</item>
        <item name="android:navigationBarColor">@color/surface_page</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/surface_page</item>
    </style>
</resources>
